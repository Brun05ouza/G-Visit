# Firebase (obrigatório para produção)
# Copie para .env.local e preencha com os dados do seu projeto no Firebase Console:
# https://console.firebase.google.com/ > Projeto > Configurações do projeto > Seus apps

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Se essas variáveis não estiverem definidas, o app usa modo mock (dados em localStorage).
